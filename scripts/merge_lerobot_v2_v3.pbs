#!/bin/bash
#PBS -N lerobot_merge
#PBS -q regular-g
#PBS -W group_list=gw13
#PBS -l select=1
#PBS -l walltime=04:00:00
#PBS -j oe

set -euo pipefail

cd "$PBS_O_WORKDIR"
mkdir -p outputs
export PYTHONPATH="$PBS_O_WORKDIR/.merge-tools${PYTHONPATH:+:$PYTHONPATH}"
python scripts/merge_lerobot_v2_v3.py --output data/record-merged
